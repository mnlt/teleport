    "supabase": {
      "category": "A",
      "name": "Supabase",
      "description": "Projects, database, auth, storage (Management API + Project REST)",
      "npm_package": "@supabase/mcp-server-supabase",
      "npm_version": "0.7.0",
      "mcp_server_default_name": "supabase",
      "env_var": "SUPABASE_ACCESS_TOKEN",
      "extra_env_vars_per_project": [
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "rest_endpoint": "https://api.supabase.com/v1",
      "project_rest_endpoint": "{SUPABASE_URL}/rest/v1",
      "auth": {
        "management": {
          "type": "bearer",
          "header": "Authorization",
          "format": "Bearer {SUPABASE_ACCESS_TOKEN}"
        },
        "project_rest": {
          "type": "bearer-and-apikey",
          "headers": {
            "Authorization": "Bearer {SUPABASE_ANON_KEY or SERVICE_ROLE_KEY}",
            "apikey": "{SUPABASE_ANON_KEY or SERVICE_ROLE_KEY}"
          },
          "note": "Supabase project REST requires BOTH Authorization Bearer AND apikey header with the same value"
        }
      },
      "docs": "https://supabase.com/docs/reference/api/introduction",
      "key_format": "sbp_* (management PAT), eyJ* (anon/service JWT)",
      "verified": true,
      "_note": "Supabase has two auth surfaces: account Management API (sbp_*) and per-project REST (anon/service keys). Setup skill needs to ask which the user wants to migrate.",
      "baseline_tokens": 5500,
      "signup_url": "https://supabase.com/dashboard/account/tokens",
      "key_format_regex": "^sbp_[a-f0-9]+$",
      "key_example": "sbp_* (management PAT)",
      "friction": "low",
      "friction_note": "free; for management API. Project-level anon/service keys are separate (dashboard \u2192 project settings)"
    },
