{
  "version": "0.1.0",
  "updated_at": "2026-04-21",
  "_notes": "Knowledge base for MCP-wrapper skills. Each entry documents the canonical env var, REST endpoint, and auth scheme so the setup skill can migrate credentials and the meta-skill can bypass MCP to HTTP. All 'verified: true' fields confirmed via npm registry, official docs, and context7 on 2026-04-21.",
  "mcps": {
    "context7": {
      "category": "A",
      "name": "Context7",
      "description": "Up-to-date library documentation",
      "npm_package": "@upstash/context7-mcp",
      "npm_version": "2.1.8",
      "hosted_mcp_url": "https://mcp.context7.com/mcp",
      "mcp_server_default_name": "context7",
      "env_var": "CONTEXT7_API_KEY",
      "rest_endpoint": "https://context7.com/api/v1",
      "auth": {
        "type": "bearer",
        "header": "Authorization",
        "format": "Bearer {token}"
      },
      "docs": "https://context7.com/docs/api-guide",
      "key_format": "ctx7sk-*",
      "verified": true,
      "baseline_tokens": 1500,
      "signup_url": "https://context7.com/dashboard",
      "key_format_regex": "^ctx7sk-[0-9a-f-]+$",
      "key_example": "ctx7sk-...",
      "friction": "low",
      "friction_note": "free tier, ~1 min"
    },
    "github": {
      "category": "A",
      "name": "GitHub",
